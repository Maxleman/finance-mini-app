# Скопируй этот файл в .env и заполни своими значениями.
# В Render эти переменные задаются через интерфейс (Environment), .env туда не заливается.

# Токен бота от @BotFather
BOT_TOKEN=вставь_сюда_свой_токен

# Строка подключения к базе данных Supabase (Postgres).
# Найти можно в Supabase: Connect → Direct → Connection string.
# Не забудь подставить свой реальный пароль вместо [YOUR-PASSWORD].
DATABASE_URL=postgresql://postgres.xxxxx:твой_пароль@aws-x-xx-xxxx.pooler.supabase.com:6543/postgres

# Порт (Render сам подставит свой, локально можно оставить 3000)
PORT=3000

# URL твоего Mini App (после деплоя на Render будет вида https://имя-сервиса.onrender.com)
WEBAPP_URL=https://your-app-name.onrender.com
